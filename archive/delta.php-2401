				wachthond($extdebug,3, 	"### customField [NEW] datatype",	$customFieldDataType);
				wachthond($extdebug,3, 	"### customField [NEW] htmltype",	$customFieldHtmlType);

				if (empty($newvalue))	{ $newvalue = '(leeggemaakt)'; 	}

