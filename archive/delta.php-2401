					wachthond($extdebug,3, "##############################################################");

					if (empty($oldvalue))	{ $oldvalue = '(was leeg)'; 	}
					if ($oldvalue == '1') 	{ $oldvalue = 'ja';  			}
					if ($oldvalue == '0') 	{ $oldvalue = 'nee'; 			}					

