				 	wachthond($extdebug,3, "### DELTA NEW - $fieldid DATA TYPE: $customFieldDataType","[HTML: BOOLEAN]");
					wachthond($extdebug,3, "##############################################################");

					if ($newvalue == '1') 	{ $newvalue = 'ja';  			}
					if ($newvalue == '0') 	{ $newvalue = 'nee'; 			}

